---
interface HowToStep {
  name: string;
  text: string;
}

interface Props {
  name: string;
  description: string;
  steps: HowToStep[];
  image?: string;
}

const {
  name,
  description,
  steps,
  image,
} = Astro.props;

const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": name,
  "description": description,
  "step": steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": step.name,
    "text": step.text,
  })),
};

if (image) {
  schema.image = image;
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
