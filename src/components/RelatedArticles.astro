---
import { getCollection } from 'astro:content';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;

const allArticles = await getCollection('articles');
const related = allArticles.filter((a) => slugs.includes(a.id));
---

{related.length > 0 && (
  <aside class="related">
    <span class="label">Continue Reading</span>
    <div class="related__list">
      {related.map((article) => (
        <a href={`/articles/${article.id}`} class="related__link">
          <span class="related__category">{article.data.category}</span>
          <span class="related__title">{article.data.title}</span>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(184, 175, 166, 0.2);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .related__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .related__link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--space-sm) 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(184, 175, 166, 0.1);
    transition: opacity 0.3s ease;
  }

  .related__link:hover {
    opacity: 0.7;
  }

  .related__category {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-taupe);
  }

  .related__title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-charcoal);
  }
</style>
