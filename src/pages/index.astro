---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);

const categories = [
  { slug: 'bible', label: 'Bible', numeral: 'I' },
  { slug: 'discipline', label: 'Discipline', numeral: 'II' },
  { slug: 'relationships', label: 'Relationships', numeral: 'III' },
  { slug: 'purpose', label: 'Purpose', numeral: 'IV' },
  { slug: 'fitness', label: 'Fitness', numeral: 'V' },
];
---

<Base
  title="Home"
  description="A King's Lifestyle teaches young men ages 13-26 how to become better men through biblical wisdom and modern practical knowledge. Five categories of genuine transformation."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "A King's Lifestyle",
      "url": "https://akingslifestyle.com",
      "description": "Genuine transformation into a better man through biblical wisdom and modern practical knowledge.",
      "publisher": {
        "@type": "Organization",
        "name": "A King's Lifestyle"
      }
    })} />
  </Fragment>

  <!-- Hero — image-dominant with minimal text overlay -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title fade-in">
        The making of<br />better men.
      </h1>
      <div class="divider fade-in fade-in-delay-1"></div>
    </div>
  </section>

  <!-- Categories -->
  <section class="categories">
    <div class="categories__inner">
      <span class="label fade-in">Explore</span>
      <nav class="categories__grid" aria-label="Content categories">
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="cat-card">
            <span class="cat-card__numeral">{cat.numeral}</span>
            <span class="cat-card__name">{cat.label}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Latest Articles -->
  {latestArticles.length > 0 && (
    <section class="latest">
      <div class="latest__inner">
        <span class="label">Recent</span>
        <div class="latest__grid">
          {latestArticles.map((article) => (
            <a href={`/articles/${article.id}`} class="article-card">
              <span class="article-card__category">{article.data.category}</span>
              <h3 class="article-card__title">{article.data.title}</h3>
              <p class="article-card__desc">{article.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Mission -->
  <section class="mission">
    <div class="mission__inner content-narrow">
      <span class="label">Our Conviction</span>
      <p class="mission__text">
        Every man carries the weight of who he could become.
        We exist to close that gap — through Scripture, discipline,
        and the quiet daily work of transformation.
        No shortcuts. No hype. Just the honest path forward.
      </p>
    </div>
  </section>

  <!-- Ethos -->
  <section class="ethos">
    <div class="ethos__inner content-narrow">
      <blockquote class="ethos__quote">
        "It is the glory of God to conceal a matter; to search out a matter is the glory of kings."
      </blockquote>
      <cite class="ethos__cite">Proverbs 25 : 2</cite>
    </div>
  </section>
</Base>

<style>
  /* Hero — image-dominant */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    min-height: 90vh;
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    background: var(--color-charcoal);
    background-image:
      radial-gradient(ellipse at 30% 40%, rgba(74, 74, 58, 0.4) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(140, 123, 107, 0.15) 0%, transparent 50%);
    overflow: hidden;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.7) 0%,
      rgba(26, 26, 26, 0.2) 40%,
      transparent 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.08;
    color: var(--color-ivory);
    letter-spacing: -0.02em;
  }

  .hero .divider {
    background: rgba(250, 247, 242, 0.4);
  }

  /* Categories */
  .categories {
    padding: var(--space-xl) var(--space-md);
    background: var(--color-warm-white);
  }

  .categories__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .categories__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(184, 175, 166, 0.15);
    border: 1px solid rgba(184, 175, 166, 0.15);
  }

  @media (min-width: 640px) {
    .categories__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: var(--space-lg) var(--space-sm);
    background: var(--color-warm-white);
    text-decoration: none;
    transition: background 0.4s ease;
  }

  .cat-card:hover {
    background: var(--color-ivory);
    opacity: 1;
  }

  .cat-card__numeral {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-taupe);
    letter-spacing: 0.05em;
  }

  .cat-card__name {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-charcoal);
  }

  /* Latest Articles */
  .latest {
    padding: var(--space-xl) var(--space-md);
  }

  .latest__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .latest__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(184, 175, 166, 0.1);
  }

  @media (min-width: 640px) {
    .latest__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .latest__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: var(--space-md);
    background: var(--color-ivory);
    text-decoration: none;
    transition: background 0.4s ease;
  }

  .article-card:hover {
    background: var(--color-cream);
    opacity: 1;
  }

  .article-card__category {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .article-card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-black);
  }

  .article-card__desc {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-greige);
    max-width: 40ch;
  }

  /* Mission */
  .mission {
    padding: var(--space-xl) var(--space-md);
    background: var(--color-warm-white);
  }

  .mission__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .mission__text {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    font-weight: 300;
    line-height: 2;
    color: var(--color-charcoal);
    max-width: 55ch;
  }

  /* Ethos */
  .ethos {
    padding: var(--space-2xl) var(--space-md);
    text-align: center;
  }

  .ethos__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .ethos__quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.6;
    color: var(--color-charcoal);
    max-width: 600px;
    border: none;
    padding: 0;
  }

  .ethos__cite {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-taupe);
  }
</style>
