---
import Base from './Base.astro';
import SchemaArticle from '../components/SchemaArticle.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';
import CategoryTag from '../components/CategoryTag.astro';
import LastUpdated from '../components/LastUpdated.astro';
import FAQ from '../components/FAQ.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  datePublished: string;
  dateModified: string;
  image?: string;
  faq?: { question: string; answer: string }[];
  relatedSlugs?: string[];
}

const {
  title,
  description,
  category,
  datePublished,
  dateModified,
  image,
  faq = [],
  relatedSlugs = [],
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site).toString();
---

<Base title={title} description={description} image={image}>
  <Fragment slot="schema">
    <SchemaArticle
      title={title}
      description={description}
      url={url}
      datePublished={datePublished}
      dateModified={dateModified}
      image={image}
    />
    {faq.length > 0 && <SchemaFAQ items={faq} />}
  </Fragment>

  <article class="article">
    <header class="article__header">
      <CategoryTag category={category} />
      <h1 class="article__title">{title}</h1>
      <p class="article__description">{description}</p>
      <div class="divider"></div>
    </header>

    <div class="article__body content-narrow">
      <slot />
    </div>

    <footer class="article__footer content-narrow">
      {faq.length > 0 && <FAQ items={faq} />}
      {relatedSlugs.length > 0 && <RelatedArticles slugs={relatedSlugs} />}
      <LastUpdated date={dateModified} />
    </footer>
  </article>
</Base>

<style>
  .article {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .article__header {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-xl) 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .article__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.15;
    color: var(--color-black);
    letter-spacing: -0.02em;
    margin-top: var(--space-xs);
  }

  .article__description {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-greige);
    max-width: 55ch;
  }

  /* Article body typography */
  .article__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.85;
    color: var(--color-charcoal);
  }

  .article__body :global(h2) {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 400;
    color: var(--color-black);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    line-height: 1.25;
  }

  .article__body :global(h3) {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 400;
    color: var(--color-black);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xs);
  }

  .article__body :global(p) {
    margin-bottom: var(--space-sm);
    max-width: 65ch;
  }

  .article__body :global(blockquote) {
    border-left: 2px solid var(--color-taupe);
    padding-left: var(--space-sm);
    margin: var(--space-md) 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--color-olive);
    line-height: 1.7;
  }

  .article__body :global(ul),
  .article__body :global(ol) {
    margin: var(--space-sm) 0;
    padding-left: 1.5rem;
  }

  .article__body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .article__body :global(strong) {
    font-weight: 500;
    color: var(--color-black);
  }

  .article__footer {
    padding-bottom: var(--space-xl);
  }
</style>
